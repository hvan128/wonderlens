# Sao chép thành .env và điền key thật. KHÔNG commit .env.
# Lấy key tại https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret để app xác thực với proxy (chống lạm dụng đốt quota).
# App gửi qua header x-app-token; phải khớp giá trị này.
# Để trống = tắt kiểm tra (chỉ dùng khi dev cục bộ).
APP_SHARED_SECRET=dev-wonderlens

# (Tuỳ chọn) Cấu hình text-to-video Sora. Bỏ trống = dùng mặc định bên dưới.
# VIDEO_SECONDS hợp lệ với sora-2 thường là 4/8/12 — clip càng dài càng đắt.
# sora-2 ~$0.10/giây (720p); sora-2-pro đắt hơn nhiều.
VIDEO_MODEL=sora-2
VIDEO_SIZE=1280x720
VIDEO_SECONDS=8
