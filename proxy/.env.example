# Sao chép thành .env và điền key thật. KHÔNG commit .env.
# Lấy key tại https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret để app xác thực với proxy (chống lạm dụng đốt quota).
# App gửi qua header x-app-token; phải khớp giá trị này.
# Để trống = tắt kiểm tra (chỉ dùng khi dev cục bộ).
APP_SHARED_SECRET=dev-wonderlens

# (Tuỳ chọn) Cấu hình text-to-video Sora. Bỏ trống = dùng mặc định bên dưới.
# VIDEO_SECONDS hợp lệ với sora-2 thường là 4/8/12 — clip càng dài càng đắt.
# sora-2 ~$0.10/giây (720p); sora-2-pro đắt hơn nhiều.
VIDEO_MODEL=sora-2
VIDEO_SIZE=1280x720
VIDEO_SECONDS=8

# (Tuỳ chọn) Giọng đọc OpenAI Text-to-Speech cho trang chi tiết. Bỏ trống = mặc định.
# TTS_MODEL: gpt-4o-mini-tts (điều tốc bằng instructions) | tts-1 | tts-1-hd (nhận speed).
# TTS_VOICE: alloy|ash|ballad|coral|echo|fable|onyx|nova|sage|shimmer|verse.
# TTS_INSTRUCTIONS chỉ áp dụng cho gpt-4o-mini-tts (mặc định đã đặt nhịp NHANH GỌN).
# TTS_SPEED chỉ áp dụng cho tts-1/tts-1-hd (0.25–4.0; mặc định 1.15 = nhanh hơn).
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=nova
TTS_SPEED=1.15
# TTS_INSTRUCTIONS=Đọc bằng tiếng Việt, giọng ấm áp thân thiện, nhịp độ nhanh gọn, vui tươi cho trẻ 6-10 tuổi.
