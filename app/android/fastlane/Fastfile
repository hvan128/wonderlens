default_platform(:android)

# AAB produced by `flutter build appbundle --release` (release signingConfig đã
# wire trong app/build.gradle.kts, đọc android/key.properties).
def aab_path
  glob = File.expand_path("../../build/app/outputs/bundle/release/*.aab", __dir__)
  path = Dir.glob(glob).max_by { |f| File.mtime(f) }
  UI.user_error!("No AAB found — run scripts/build-appbundle.sh first") unless path
  path
end

platform :android do
  desc "Upload AAB to the Internal testing track"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  desc "Upload AAB to the Closed testing (alpha) track — bắt buộc cho quyền Production tài khoản cá nhân"
  lane :closed do
    upload_to_play_store(
      track: "alpha",
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  desc "Upload AAB to Production as a DRAFT (review/rollout stays manual in the Console)"
  lane :production do
    upload_to_play_store(
      track: "production",
      aab: aab_path,
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end
end
