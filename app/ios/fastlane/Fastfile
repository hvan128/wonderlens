default_platform(:ios)

# IPA produced by `flutter build ipa --release` (run scripts/build-release.sh first).
# Globbed so it works regardless of the product/scheme name Flutter assigns.
def ipa_path
  # Anchor to the Flutter project root (ios/fastlane -> ios -> root) so the glob
  # works regardless of fastlane's current working directory.
  glob = File.expand_path("../../build/ios/ipa/*.ipa", __dir__)
  path = Dir.glob(glob).max_by { |f| File.mtime(f) }
  UI.user_error!("No IPA found in build/ios/ipa/ — run scripts/build-release.sh first") unless path
  path
end

def asc_api_key
  # Prefer base64 key content (works on any machine / CI without the .p8 on disk);
  # fall back to a local .p8 file path for same-machine runs.
  if ENV["ASC_KEY_CONTENT"] && !ENV["ASC_KEY_CONTENT"].empty?
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )
  else
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"],
      in_house: false
    )
  end
end

platform :ios do
  desc "Register bundle id + create the ASC app record via official API (run once)"
  # produce cần đăng nhập Apple ID (web session) nên không dùng được với API
  # key — gọi thẳng Spaceship::ConnectAPI thay thế.
  lane :create_app do
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token

    id = "com.wonderlens.wonderlens"
    if Spaceship::ConnectAPI::BundleId.all.any? { |b| b.identifier == id }
      UI.message("Bundle ID đã đăng ký sẵn")
    else
      Spaceship::ConnectAPI::BundleId.create(name: "WonderLens", identifier: id, platform: "IOS")
      UI.success("Đã đăng ký Bundle ID ✓")
    end

    app = Spaceship::ConnectAPI::App.find(id)
    if app
      UI.message("App record đã tồn tại: #{app.name}")
    else
      Spaceship::ConnectAPI::App.create(
        name: "WonderLens",
        version_string: "1.0.0",
        sku: id,
        primary_locale: "vi",
        bundle_id: id,
        platforms: ["IOS"]
      )
      UI.success("Đã tạo app record WonderLens trên App Store Connect ✓")
    end
  end

  desc "Build signed App Store IPA (ASC API key, no Xcode account)"
  lane :build_ipa do
    key = asc_api_key
    # API key của team không có quyền cloud signing → không dựa vào
    # -allowProvisioningUpdates ở bước export. Thay vào đó sigh tạo/tải profile
    # App Store qua API chính thức rồi export theo manual mapping.
    get_provisioning_profile(
      api_key: key,
      app_identifier: "com.wonderlens.wonderlens",
      readonly: false
    )
    auth = "-allowProvisioningUpdates " \
      "-authenticationKeyPath #{ENV['ASC_KEY_FILEPATH']} " \
      "-authenticationKeyID #{ENV['ASC_KEY_ID']} " \
      "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}"
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      xcargs: auth,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.wonderlens.wonderlens" =>
            lane_context[SharedValues::SIGH_NAME]
        }
      },
      output_directory: File.expand_path("../../build/ios/ipa", __dir__),
      output_name: "wonderlens.ipa",
      clean: false
    )
  end

  desc "In trạng thái version/localization trên ASC (chẩn đoán deliver 'No data')"
  lane :diag do
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.wonderlens.wonderlens")
    UI.user_error!("app not found") unless app
    vs = app.get_app_store_versions
    UI.important("versions: #{vs.map { |v| "#{v.version_string} (#{v.app_store_state})" }.join(', ')}")
    info = app.fetch_edit_app_info || app.fetch_live_app_info
    UI.important("edit app_info id: #{info&.id || 'NONE'}")
    if info
      locs = info.get_app_info_localizations.map(&:locale)
      UI.important("app_info locales: #{locs.join(', ')}")
    end
    vs.each do |v|
      vlocs = v.get_app_store_version_localizations.map(&:locale)
      UI.important("v#{v.version_string} locales: #{vlocs.join(', ')}")
    end
  end

  desc "Xem trạng thái subscription (state + trường còn thiếu) trên ASC — chỉ đọc"
  lane :iap_status do
    require "net/http"
    require "json"

    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token
    jwt = token.text
    get = lambda do |path|
      uri = URI("https://api.appstoreconnect.apple.com/#{path}")
      req = Net::HTTP::Get.new(uri)
      req["Authorization"] = "Bearer #{jwt}"
      res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      res.body.nil? || res.body.empty? ? {} : JSON.parse(res.body)
    end

    app = Spaceship::ConnectAPI::App.find("com.wonderlens.wonderlens")
    UI.user_error!("app not found") unless app
    groups = get.call("v1/apps/#{app.id}/subscriptionGroups?limit=200")
    groups.fetch("data", []).each do |group|
      UI.important("Group: #{group.dig('attributes', 'referenceName')} (#{group['id']})")
      subs = get.call("v1/subscriptionGroups/#{group['id']}/subscriptions?limit=200")
      subs.fetch("data", []).each do |sub|
        attrs = sub["attributes"]
        UI.important("  #{attrs['productId']}: state=#{attrs['state']}")
        loc = get.call("v1/subscriptions/#{sub['id']}/subscriptionLocalizations?limit=200")
        UI.important("    localizations: #{loc.fetch('data', []).map { |l| l.dig('attributes', 'locale') }.join(', ')}")
        price = get.call("v1/subscriptions/#{sub['id']}/prices?limit=20")
        UI.important("    prices: #{price.fetch('data', []).length}")
        avail = get.call("v1/subscriptions/#{sub['id']}/subscriptionAvailability")
        UI.important("    availability: #{avail['data'] ? 'set' : 'MISSING'}")
        ss = get.call("v1/subscriptions/#{sub['id']}/appStoreReviewScreenshot")
        state = ss.dig("data", "attributes", "assetDeliveryState", "state") rescue nil
        UI.important("    review screenshot: #{ss['data'] ? (state || 'uploaded, no state') : 'MISSING'}")
        plan = get.call("v1/subscriptions/#{sub['id']}/planAvailabilities?limit=20")
        UI.important("    plan availabilities: #{plan.fetch('data', []).length}")
      end
    end
  end

  desc "Set text metadata qua Spaceship trực tiếp (né bug deliver 'No data' với app mới)"
  lane :set_metadata do
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.wonderlens.wonderlens")
    meta = File.expand_path("metadata", __dir__)
    read = ->(p) { File.read(File.join(meta, p)).strip }

    v = app.get_edit_app_store_version
    vloc = v.get_app_store_version_localizations.find { |l| l.locale == "vi" }
    vloc.update(attributes: {
      description: read.call("vi/description.txt"),
      keywords: read.call("vi/keywords.txt"),
      supportUrl: read.call("vi/support_url.txt")
    })
    UI.success("version vi: description/keywords/supportUrl ✓")

    v.update(attributes: { copyright: read.call("copyright.txt") })
    UI.success("copyright ✓")

    info = app.fetch_edit_app_info
    iloc = info.get_app_info_localizations.find { |l| l.locale == "vi" }
    iloc.update(attributes: {
      subtitle: File.read(File.expand_path("metadata-held/subtitle.txt", __dir__)).strip
    })
    UI.success("subtitle ✓")

    info.update_categories(category_id_map: {
      primary_category_id: "EDUCATION",
      secondary_category_id: "ENTERTAINMENT"
    })
    UI.success("categories ✓")
  end

  desc "Set App Review contact + notes qua Spaceship (deliver bug với app mới)"
  lane :set_review do
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.wonderlens.wonderlens")
    v = app.get_edit_app_store_version
    notes = File.read(
      File.expand_path("metadata-held/review_notes.txt", __dir__),
    ).strip
    attrs = {
      contactFirstName: "Hải Văn",
      contactLastName: "Ngô",
      contactPhone: ENV["ASC_REVIEW_PHONE"],
      contactEmail: "van.nh120802@gmail.com",
      notes: notes
    }
    # fetch ném "No data" khi detail chưa tồn tại (bug spaceship) → thử create
    # trước, đã có thì rơi vào update.
    begin
      v.create_app_store_review_detail(attributes: attrs)
    rescue => e
      raise unless e.message.include?("already exists") ||
        e.message.include?("entity") || e.message.include?("409")
      v.fetch_app_store_review_detail.update(attributes: attrs)
    end
    UI.success("App Review contact + notes ✓")
  end

  desc "Gửi version 1.0 cho Apple duyệt (đẩy sang Waiting for Review)"
  lane :submit_review do
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.wonderlens.wonderlens")
    v = app.get_edit_app_store_version
    UI.user_error!("không có version edit") unless v
    UI.important("trạng thái trước: #{v.app_store_state}")
    # API cũ (appStoreVersionSubmissions) đã bị Apple ngưng → dùng luồng
    # Review Submission mới: tạo submission → thêm version làm item → submit.
    sub = app.get_ready_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS) ||
      app.create_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS)
    sub.add_app_store_version_to_review_items(app_store_version_id: v.id)
    sub.submit_for_review
    UI.success("Đã gửi duyệt ✓ — version giờ ở Waiting for Review")
  end

  desc "Upload IPA to TestFlight"
  lane :beta do
    upload_to_testflight(
      api_key: asc_api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Validate ASC API key (key id + issuer) against the app"
  lane :check_key do
    n = latest_testflight_build_number(
      api_key: asc_api_key,
      app_identifier: "com.wonderlens.wonderlens",
      initial_build_number: 0
    )
    UI.success("ASC key OK ✓ — latest TestFlight build number: #{n}")
  end

  desc "Upload binary + metadata to App Store. Submits for review only when SUBMIT_FOR_REVIEW=true"
  lane :release do
    upload_to_app_store(
      api_key: asc_api_key,
      ipa: ipa_path,
      skip_screenshots: true, # screenshots managed via lane :screenshots
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: ENV["SUBMIT_FOR_REVIEW"] == "true",
      automatic_release: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end

  desc "Upload App Store metadata (text only, no screenshots, no submit)"
  lane :metadata do
    upload_to_app_store(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: false
    )
  end

  desc "Upload screenshots only (locale vi) — staged in fastlane/screenshots/vi"
  lane :screenshots do
    upload_to_app_store(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      force: true
    )
  end

  desc "Nộp lại bản sửa: chờ build xử lý → hủy submission cũ → chọn build → gửi duyệt"
  # Dùng sau khi upload binary qua lane :beta. RESUBMIT_BUILD = số build (mặc
  # định build mới nhất đã xử lý). Xử lý luôn version đang REJECTED/
  # UNRESOLVED_ISSUES: hủy submission cũ để giải phóng version rồi gửi qua luồng
  # Review Submission mới (API cũ appStoreVersionSubmissions đã bị Apple ngưng).
  lane :resubmit do
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.wonderlens.wonderlens")
    want = ENV["RESUBMIT_BUILD"]

    # 1) Tìm build đích, chờ Apple xử lý xong (processing_state = VALID).
    build = nil
    40.times do
      builds = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 10)
      build = want ? builds.find { |b| b.version == want } : builds.first
      break if build && build.processing_state == "VALID"
      UI.message("chờ build #{want || 'mới nhất'} xử lý (#{build&.processing_state || 'chưa thấy'})")
      sleep(45)
    end
    UI.user_error!("build chưa xử lý xong") unless build && build.processing_state == "VALID"
    UI.success("dùng build #{build.version} (#{build.id})")

    # 2) Hủy mọi submission còn hoạt động để giải phóng version.
    Spaceship::ConnectAPI.get_review_submissions(app_id: app.id).to_models.each do |s|
      next if %w[COMPLETE CANCELING].include?(s.state)
      UI.message("hủy submission #{s.id} (#{s.state})")
      s.cancel_submission rescue UI.error("hủy #{s.id}: #{$!.message}")
    end

    # 3) Nếu version đã được duyệt và đang chờ developer release, phải reject
    # bản chờ release trước thì ASC mới cho sửa build.
    unless app.get_edit_app_store_version
      if app.reject_version_if_possible!(platform: Spaceship::ConnectAPI::Platform::IOS)
        UI.message("đã hủy bản chờ release để sửa build")
        sleep(12)
      end
    end

    # 4) Chọn build cho version + verify.
    v = app.get_edit_app_store_version
    UI.user_error!("không lấy được edit app store version sau khi hủy release") unless v
    v.select_build(build_id: build.id)
    sleep(6)
    v = app.get_edit_app_store_version
    b = (v.build rescue nil)
    UI.user_error!("build chưa đổi (đang #{b&.version || 'NONE'})") unless b&.version == build.version
    UI.success("version dùng build #{b.version}")

    # 5) Submission (sẵn có hoặc mới) + thêm version + gửi duyệt.
    sub = app.get_ready_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS) ||
      app.create_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS)
    sub.add_app_store_version_to_review_items(app_store_version_id: v.id) rescue UI.important("thêm version: #{$!.message}")
    sub.submit_for_review
    UI.success("Đã gửi duyệt lại build #{build.version} ✓ (#{sub.id})")
  end

  desc "Nhân giá VNM sang mọi lãnh thổ còn thiếu (subscriptionSubmissions đòi giá đủ mọi lãnh thổ app bán)"
  lane :equalize_prices do
    require "net/http"
    require "json"

    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token
    jwt = token.text
    get = lambda do |path|
      uri = URI("https://api.appstoreconnect.apple.com/#{path}")
      req = Net::HTTP::Get.new(uri)
      req["Authorization"] = "Bearer #{jwt}"
      res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      res.body.nil? || res.body.empty? ? {} : JSON.parse(res.body)
    end
    post = lambda do |path, body|
      uri = URI("https://api.appstoreconnect.apple.com/#{path}")
      req = Net::HTTP::Post.new(uri)
      req["Authorization"] = "Bearer #{jwt}"
      req["Content-Type"] = "application/json"
      req.body = JSON.generate(body)
      res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
      parsed = res.body.nil? || res.body.empty? ? {} : JSON.parse(res.body)
      return parsed if res.is_a?(Net::HTTPSuccess)

      message = parsed["errors"]&.map { |e| "#{e['code']}: #{e['detail']}" }&.join(" | ")
      raise "POST #{path} failed (#{res.code}): #{message || res.body}"
    end

    app = Spaceship::ConnectAPI::App.find("com.wonderlens.wonderlens")
    groups = get.call("v1/apps/#{app.id}/subscriptionGroups?limit=200")
    groups.fetch("data", []).each do |group|
      subs = get.call("v1/subscriptionGroups/#{group['id']}/subscriptions?limit=200")
      subs.fetch("data", []).each do |s|
        sub_id = s["id"]
        product_id = s.dig("attributes", "productId")

        # Apple không trả "relationships" trên subscriptionPrices trừ khi có
        # ?include= — thiếu include khiến base_point_id/have_territories rỗng.
        existing = get.call("v1/subscriptions/#{sub_id}/prices?limit=200&include=subscriptionPricePoint,territory")
        base_price = existing.fetch("data", []).first
        unless base_price
          UI.important("#{product_id}: chưa có giá gốc, bỏ qua")
          next
        end
        base_point_id = base_price.dig("relationships", "subscriptionPricePoint", "data", "id")
        have_territories = existing.fetch("data", []).map { |p| p.dig("relationships", "territory", "data", "id") }.compact.to_set

        equalizations = get.call("v1/subscriptionPricePoints/#{base_point_id}/equalizations?limit=200&include=territory")
        added = 0
        equalizations.fetch("data", []).each do |point|
          territory_id = point.dig("relationships", "territory", "data", "id")
          next if territory_id.nil? || have_territories.include?(territory_id)

          payload = {
            data: {
              type: "subscriptionPrices",
              relationships: {
                subscription: { data: { type: "subscriptions", id: sub_id } },
                territory: { data: { type: "territories", id: territory_id } },
                subscriptionPricePoint: { data: { type: "subscriptionPricePoints", id: point["id"] } }
              }
            }
          }
          begin
            post.call("v1/subscriptionPrices", payload)
            added += 1
          rescue => e
            UI.important("#{product_id} #{territory_id}: #{e.message}")
          end
        end
        UI.success("#{product_id}: thêm giá cho #{added} lãnh thổ ✓")
      end
    end
  end

  desc "Chờ build xử lý → chọn build cho version → gắn version vào review submission → gửi duyệt (Apple tự gộp subscription đầu tiên)"
  lane :submit_with_iap do
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_FILEPATH"])
    )
    Spaceship::ConnectAPI.token = token

    app = Spaceship::ConnectAPI::App.find("com.wonderlens.wonderlens")
    want = ENV["RESUBMIT_BUILD"]

    build = nil
    60.times do
      builds = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 10)
      build = want ? builds.find { |b| b.version == want } : builds.first
      break if build && build.processing_state == "VALID"
      UI.message("chờ build #{want || 'mới nhất'} xử lý (#{build&.processing_state || 'chưa thấy'})")
      sleep(30)
    end
    UI.user_error!("build chưa xử lý xong") unless build && build.processing_state == "VALID"
    UI.success("dùng build #{build.version} (#{build.id})")

    v = app.get_edit_app_store_version
    v.select_build(build_id: build.id)
    sleep(6)
    v = app.get_edit_app_store_version
    b = (v.build rescue nil)
    UI.user_error!("build chưa đổi (đang #{b&.version || 'NONE'})") unless b&.version == build.version
    UI.success("version #{v.version_string} dùng build #{b.version}")

    vloc = v.get_app_store_version_localizations.find { |l| l.locale == "vi" }
    vloc.update(attributes: {
      whatsNew: "Ra mắt WonderLens Plus: mở khoá thêm lượt soi vật và lưu hành trình khám phá."
    })
    UI.success("whatsNew (vi) ✓")

    # subscriptionSubmissions từ chối 409 FIRST_SUBSCRIPTION_MUST_BE_SUBMITTED_ON_VERSION
    # cho subscription đầu tiên của app — không gọi riêng được, Apple tự gộp
    # subscription MISSING_METADATA (đã đủ field) vào review submission của
    # version khi submit_for_review bên dưới.
    sub = app.get_ready_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS) ||
      app.create_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS)
    sub.add_app_store_version_to_review_items(app_store_version_id: v.id) rescue UI.important("thêm version: #{$!.message}")
    sub.submit_for_review
    UI.success("Đã gửi duyệt version #{v.version_string} (build #{b.version}) ✓ (#{sub.id})")
  end
end
